# Optional: your Coachy / Teachable / Plug&Pay member area (https://...).
# If unset, "Log in" in the header goes to /course on this site instead.
# NEXT_PUBLIC_COURSE_PLATFORM_URL=

# Supabase (copy to .env.local — do not commit secrets)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only: create users after Stripe payment (Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server) — never expose STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET to the client
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (Dashboard webhook signing secret, or `stripe listen` for local)
# Optional: use a Dashboard Price instead of inline €39 (EUR) in code
# STRIPE_PRICE_ID=price_...

# Public site URL for Stripe success/cancel redirects (production)
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
