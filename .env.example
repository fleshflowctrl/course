# Optional: your Coachy / Teachable / Plug&Pay member area (https://...).
# If unset, "Log in" in the header goes to /course on this site instead.
# NEXT_PUBLIC_COURSE_PLATFORM_URL=

# Supabase (copy to .env.local — do not commit secrets)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
#
# Course videos (private Storage bucket). Lesson 1 = first video in Module 1, … lesson 30 = last in Module 4.
# NEXT_PUBLIC_COURSE_VIDEO_BUCKET=course-videos
# Optional path: object key template (default 01.mp4 … 30.mp4). Placeholders: {n} {nn} {nnn}
# NEXT_PUBLIC_COURSE_VIDEO_PATH_TEMPLATE={nn}.mp4
# Optional folder inside the bucket (no leading slash)
# NEXT_PUBLIC_COURSE_VIDEO_OBJECT_PREFIX=
# Server-only: create users after Stripe payment (Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=

# Run supabase/migrations in SQL Editor (purchase ledger, package_id column, etc.)

# Stripe (server) — never expose STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET to the client
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (Dashboard webhook signing secret, or `stripe listen` for local)
# Checkout uses inline EUR prices from lib/packages.ts (per selected package).
# STRIPE_PRICE_ID is not read by /api/checkout.

# Public site URL for Stripe success/cancel redirects (production)
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
